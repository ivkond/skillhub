# Used by: docker compose --env-file .env -f compose.prod.yml up -d
#
# Copy to `.env` and adjust values for your environment.

# Prebuilt application images (required)
SKILLHUB_SERVER_IMAGE=ghcr.io/ivkond/skillhub-server:latest
SKILLHUB_WEB_IMAGE=ghcr.io/ivkond/skillhub-web:latest

# Published ports on the host
SKILLHUB_SERVER_PORT=8080
SKILLHUB_WEB_PORT=80

# Spring profile(s) for the server container (recommended: docker)
SPRING_PROFILES_ACTIVE=docker

# Database
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=change-me

# Public URLs (recommended for anything beyond localhost smoke tests)
SKILLHUB_PUBLIC_BASE_URL=http://localhost
SKILLHUB_WEB_API_BASE_URL=
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000

# Optional: pin dependency images
# POSTGRES_IMAGE=postgres:16-alpine
# REDIS_IMAGE=redis:7-alpine
# MINIO_IMAGE=minio/minio:latest
