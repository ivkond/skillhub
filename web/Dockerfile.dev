FROM node:22-alpine

RUN corepack enable
RUN addgroup -S app && adduser -S app -G app

WORKDIR /app

# Install deps once at image build time; bind-mount source at runtime for fast iteration.
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile && chown -R app:app /app

USER app

EXPOSE 3000

CMD ["sh", "-lc", "if [ ! -d node_modules ] || [ ! -f node_modules/.modules.yaml ]; then pnpm install --frozen-lockfile; fi; exec pnpm exec vite --host 0.0.0.0 --port 3000 --strictPort"]
